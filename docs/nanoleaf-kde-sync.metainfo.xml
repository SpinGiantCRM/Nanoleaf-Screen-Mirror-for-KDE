<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>nanoleaf-kde-sync</id>
  <name>nanoleaf-kde-sync</name>
  <summary>Nanoleaf screen mirroring for KDE Plasma on Linux</summary>
  <description>
    <p>
      Real-time screen mirroring for supported Nanoleaf USB Edge Strips on KDE Plasma 6.
      Mirrors display edge colours to your strip with a tray app, setup wizard, calibration,
      and diagnostics.
    </p>
    <p>Supported devices: NL82K1 (0x37fa:0x8201) and NL82K2 (0x37fa:0x8202).</p>
  </description>
  <launchable type="desktop-id">nanoleaf-kde-sync.desktop</launchable>
