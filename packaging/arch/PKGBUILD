# Maintainer: nanoleaf-kde-sync contributors
pkgname=nanoleaf-kde-sync
pkgver=1.7.2
pkgrel=1
pkgdesc='Nanoleaf screen mirroring for KDE Plasma on Linux.'
arch=('x86_64')
url='https://github.com/SpinGiantCRM/Nanoleaf-Screen-Mirror-for-KDE'
license=('custom:Nanoleaf-Source-Available-Non-Commercial')
depends=(
  'python'
  'python-numpy'
  'python-pyqt6'
  'python-dbus-next'
  'python-hidapi'
  'python-dacite'
  'python-tomli-w'
)
# NOTE: `python-dacite` may require AUR enablement on Arch/CachyOS.
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
install='nanoleaf-kde-sync.install'
source=(
  "$pkgname-$pkgver.tar.gz::https://github.com/SpinGiantCRM/Nanoleaf-Screen-Mirror-for-KDE/archive/refs/tags/v$pkgver.tar.gz"
)
# Verify against the published GitHub tarball when cutting a release.
sha256sums=('SKIP')

build() {
  cd "Nanoleaf-Screen-Mirror-for-KDE-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "Nanoleaf-Screen-Mirror-for-KDE-$pkgver"

  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 docs/nanoleaf-kde-sync.desktop \
    "$pkgdir/usr/share/applications/nanoleaf-kde-sync.desktop"

  install -Dm644 assets/icons/hicolor/scalable/apps/nanoleaf-kde-sync.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/nanoleaf-kde-sync.svg"

  install -Dm644 assets/icons/hicolor/48x48/apps/nanoleaf-kde-sync.png \
    "$pkgdir/usr/share/icons/hicolor/48x48/apps/nanoleaf-kde-sync.png"

  install -Dm644 assets/icons/hicolor/128x128/apps/nanoleaf-kde-sync.png \
    "$pkgdir/usr/share/icons/hicolor/128x128/apps/nanoleaf-kde-sync.png"

  install -Dm644 assets/udev/60-nanoleaf-kde-sync.rules \
    "$pkgdir/usr/lib/udev/rules.d/60-nanoleaf-kde-sync.rules"

  install -Dm644 LICENSE \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
